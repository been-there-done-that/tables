##### Java (required by Android SDK) #####
export JAVA_HOME=$(/usr/libexec/java_home -v17)

##### Android SDK / NDK #####
export ANDROID_HOME="$HOME/Library/Android/sdk"
export ANDROID_SDK_ROOT="$ANDROID_HOME"
export ANDROID_NDK_ROOT="$ANDROID_HOME/ndk/29.0.13846066"
export NDK_HOME="$ANDROID_NDK_ROOT"

##### Tooling PATH #####
PATH_add "$ANDROID_HOME/cmdline-tools/latest/bin"
PATH_add "$ANDROID_HOME/platform-tools"
PATH_add "$JAVA_HOME/bin"

##### Sanity checks (fail fast) #####
if [ ! -d "$ANDROID_HOME" ]; then
  echo "❌ ANDROID_HOME not found at $ANDROID_HOME"
  exit 1
fi

if [ ! -d "$ANDROID_NDK_ROOT" ]; then
  echo "❌ Android NDK not found at $ANDROID_NDK_ROOT"
  exit 1
fi

if [ ! -x "$ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager" ]; then
  echo "❌ sdkmanager not found"
  exit 1
fi

if [ ! -x "$JAVA_HOME/bin/java" ]; then
  echo "❌ Java not found at $JAVA_HOME"
  exit 1
fi
